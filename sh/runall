#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
    echo "usage: runall [--debug] [source_name]" >&2
    exit 1
}

. "$SCRIPT_DIR/resolve_target.sh"

DEBUG=false
SOURCE_ARG=""

while [ $# -gt 0 ]; do
    case "$1" in
        --debug|-d)
            DEBUG=true
            shift
            ;;
        --help|-h)
            usage
            ;;
        *)
            if [ -z "$SOURCE_ARG" ]; then
                SOURCE_ARG="$1"
            else
                usage
            fi
            shift
            ;;
    esac
done

TARGET="$(resolve_target "$SOURCE_ARG")" || exit 1

if [[ "$TARGET" == *.cpp ]]; then
    SRC_BASE="${TARGET%.cpp}"
    RUN_EXE="./a.out"
    IO_DEBUG_ARGS=(--debug-source "$SRC_BASE")
    if $DEBUG; then
        RUN_EXE="./a.debug.out"
        IO_DEBUG_ARGS=(--debug-source "$SRC_BASE" --no-debug-retry)
        CPP_OUT="$RUN_EXE" "$SCRIPT_DIR/build.sh" "$SRC_BASE" debug
    else
        "$SCRIPT_DIR/build.sh" "$SRC_BASE"
    fi
    CPP_EXE="$RUN_EXE" "$SCRIPT_DIR/ioall" "${IO_DEBUG_ARGS[@]}"
    echo "=== コピーします ==="
    if command -v xclip >/dev/null 2>&1; then
        if xclip -selection clipboard < "$TARGET"; then
            echo "[Copied] $TARGET"
        else
            echo "warning: xclip failed; not copied."
        fi
    else
        echo "warning: xclip not found; not copied."
    fi
else
    "$SCRIPT_DIR/pyall.sh" "$TARGET"
fi
