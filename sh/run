#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
    echo "usage: run [--debug] [--tl ms] [sample_number] [source_name]" >&2
    echo "       run [--debug] [--tl ms] [--sample N] [source_name]" >&2
    echo "       run --interactive [--debug] [source_name]" >&2
    exit 1
}

. "$SCRIPT_DIR/resolve_target.sh"

SAMPLE_ONLY=""
DEBUG=false
INTERACTIVE=false
TL=""

SOURCE_ARG=""
while [ $# -gt 0 ]; do
    case "$1" in
        --debug|-d)
            DEBUG=true
            shift
            ;;
        --interactive|-i)
            INTERACTIVE=true
            shift
            ;;
        --sample|--only|-s)
            shift
            [ $# -gt 0 ] || usage
            SAMPLE_ONLY="$1"
            shift
            ;;
        --tl)
            shift
            [ $# -gt 0 ] || usage
            TL="$1"
            shift
            ;;
        --help|-h)
            usage
            ;;
        --)
            shift
            break
            ;;
        *)
            if [[ "$1" =~ ^run([0-9]{1,3})$ ]] && [ -z "$SAMPLE_ONLY" ]; then
                SAMPLE_ONLY="${BASH_REMATCH[1]}"
            elif [[ "$1" =~ ^[0-9]{1,3}$ ]] && [ -z "$SAMPLE_ONLY" ]; then
                SAMPLE_ONLY="$1"
            elif [ -z "$SOURCE_ARG" ]; then
                SOURCE_ARG="$1"
            else
                usage
            fi
            shift
            ;;
    esac
done

[ $# -eq 0 ] || usage

if [ -n "$SAMPLE_ONLY" ] && ! [[ "$SAMPLE_ONLY" =~ ^[0-9]{1,3}$ ]]; then
    echo "error: sample must be 0..999." >&2
    exit 1
fi

if $INTERACTIVE; then
    if [ -n "$SAMPLE_ONLY" ]; then
        echo "error: --interactive cannot be used with sample_number or --sample." >&2
        exit 1
    fi
    RUNI_ARGS=()
    if $DEBUG; then
        RUNI_ARGS+=(--debug)
    fi
    if [ -n "$SOURCE_ARG" ]; then
        RUNI_ARGS+=("$SOURCE_ARG")
    fi
    exec "$SCRIPT_DIR/runi" "${RUNI_ARGS[@]}"
fi

TARGET="$(resolve_target "$SOURCE_ARG")" || exit 1

if [[ "$TARGET" == *.cpp ]]; then
    SRC_BASE="${TARGET%.cpp}"
    RUN_EXE="./a.out"
    IO_DEBUG_ARGS=(--debug-source "$SRC_BASE")
    if $DEBUG; then
        RUN_EXE="./a.debug.out"
        IO_DEBUG_ARGS=(--debug-source "$SRC_BASE" --no-debug-retry)
        CPP_OUT="$RUN_EXE" "$SCRIPT_DIR/build.sh" "$SRC_BASE" debug
    else
        "$SCRIPT_DIR/build.sh" "$SRC_BASE"
    fi
    if [ -n "$SAMPLE_ONLY" ]; then
        CPP_EXE="$RUN_EXE" TL_MS="$TL" "$SCRIPT_DIR/ioall" "${IO_DEBUG_ARGS[@]}" --sample "$SAMPLE_ONLY"
    else
        CPP_EXE="$RUN_EXE" TL_MS="$TL" "$SCRIPT_DIR/io" term "${IO_DEBUG_ARGS[@]}"
    fi
else
    if [ -n "$SAMPLE_ONLY" ]; then
        TL_MS="$TL" "$SCRIPT_DIR/pyall.sh" --sample "$SAMPLE_ONLY" "$TARGET"
    else
        python3 "$TARGET"
    fi
fi
