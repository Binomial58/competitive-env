#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
    echo "usage: runi [--debug] [source_name]" >&2
    exit 1
}

. "$SCRIPT_DIR/resolve_target.sh"

DEBUG=false
SOURCE_ARG=""

while [ $# -gt 0 ]; do
    case "$1" in
        --debug|-d)
            DEBUG=true
            shift
            ;;
        --help|-h)
            usage
            ;;
        --)
            shift
            break
            ;;
        *)
            if [ -z "$SOURCE_ARG" ]; then
                SOURCE_ARG="$1"
            else
                usage
            fi
            shift
            ;;
    esac
done

[ $# -eq 0 ] || usage

TARGET="$(resolve_target "$SOURCE_ARG")" || exit 1

if [[ "$TARGET" == *.cpp ]]; then
    SRC_BASE="${TARGET%.cpp}"
    RUN_EXE="./a.out"
    if $DEBUG; then
        RUN_EXE="./a.debug.out"
        CPP_OUT="$RUN_EXE" "$SCRIPT_DIR/build.sh" "$SRC_BASE" debug
    else
        "$SCRIPT_DIR/build.sh" "$SRC_BASE"
    fi
    exec "$RUN_EXE"
else
    exec python3 "$TARGET"
fi
